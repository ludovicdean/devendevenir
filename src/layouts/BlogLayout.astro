---
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import RelatedArticles from "@components/RelatedArticles.astro";
import CallToAction from "@components/CallToAction.astro";
import TableOfContents from "@components/TableOfContents.astro";
import SeriesNav from "@components/SeriesNav.astro";

type Props = {
  post: CollectionEntry<"blog">["data"];
  headings?: MarkdownHeading[];
};

const { post, headings = [] } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 2);
const isExternal = !!post.url;
const base = import.meta.env.BASE_URL;
---

<meta property="og:image" content={post.banner} />
<meta property="og:title" content={post.title} />
<meta property="og:description" content={post.description} />

<BaseLayout
  title={post.title}
  description={post.description}
  data-pagefind-ignore={isExternal ? "" : undefined}
>
  <article data-pagefind-body={isExternal ? undefined : ""}>
    {
      filteredHeadings.length > 0 && (
        <TableOfContents headings={filteredHeadings} title={post.title} />
      )
    }
    <article>
      <div class="relative w-full max-w-4xl mx-auto">
        <img
          src={base + post.banner}
          class="w-full h-auto object-cover"
          alt={`Bannière pour ${post.title}`}
        />
        <div
          class="absolute bottom-0 right-0 bg-slate-900 bg-opacity-50 w-full rounded-b-lg"
        >
          <p class="text-white text-sm py-2 px-4 text-right mb-0">
            © <a
              href={post.unsplashlink}
              class="no-underline text-white hover:text-white">{post.author}</a
            > via <a
              class="no-underline text-white hover:text-white"
              href={post.authorlink}>Unsplash</a
            >
          </p>
        </div>
      </div>
      <div id="toc-anchor" class="mb-4 py-4 text-center leading-none">
        <h1 class="-mb-0.5">{post.title}</h1>
        <hr />
      </div>

      {post.series && (
        <SeriesNav seriesName={post.series.name} currentPart={post.series.part} />
      )}

      <slot />

      {post.series && (
        <SeriesNav seriesName={post.series.name} currentPart={post.series.part} />
      )}

      <CallToAction />

      {!post.series && <RelatedArticles tags={post.tags} title={post.title} />}
    </article>
  </article>
</BaseLayout>
