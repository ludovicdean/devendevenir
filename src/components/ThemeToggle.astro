<button
    type="button"
    class="theme-toggle-btn relative flex items-center justify-center size-11 md:size-10 p-0 bg-transparent rounded-full cursor-pointer transition-all duration-300 hover:scale-110 hover:rotate-[10deg] active:scale-95 motion-reduce:transition-none"
    aria-label="Toggle theme"
    title="Toggle dark/light mode"
    data-testid="theme-toggle"
>
    <svg
        class="sun-icon absolute transition-all duration-400 text-yellow-400 opacity-100 scale-100 rotate-0 dark:opacity-0 dark:scale-0 dark:-rotate-180"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <svg
        class="moon-icon absolute transition-all duration-400 text-yellow-400 opacity-0 scale-0 rotate-180 dark:opacity-100 dark:scale-100 dark:rotate-0"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
</button>

<style>
    @keyframes themeSwitch {
        0% {
            transform: scale(1) rotate(0deg);
        }
        50% {
            transform: scale(1.2) rotate(180deg);
        }
        100% {
            transform: scale(1) rotate(360deg);
        }
    }

    .theme-toggle-btn.switching {
        animation: themeSwitch 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

<script>
    const themeToggles = document.querySelectorAll(".theme-toggle-btn");
    const htmlElement = document.documentElement;

    const getTheme = () => {
        if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
        ) {
            return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
        }
        return "light";
    };

    const theme = getTheme();
    if (theme === "dark") {
        htmlElement.classList.add("dark");
    } else {
        htmlElement.classList.remove("dark");
    }

    themeToggles.forEach((btn) => {
        btn.addEventListener("click", () => {
            const isDark = htmlElement.classList.contains("dark");
            themeToggles.forEach((t) => t.classList.add("switching"));

            if (isDark) {
                htmlElement.classList.remove("dark");
                localStorage.setItem("theme", "light");
            } else {
                htmlElement.classList.add("dark");
                localStorage.setItem("theme", "dark");
            }

            setTimeout(() => {
                themeToggles.forEach((t) => t.classList.remove("switching"));
            }, 600);
        });
    });

    window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", (e) => {
            if (!localStorage.getItem("theme")) {
                if (e.matches) {
                    htmlElement.classList.add("dark");
                } else {
                    htmlElement.classList.remove("dark");
                }
            }
        });
</script>
