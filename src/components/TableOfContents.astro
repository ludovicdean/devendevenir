---
import type { MarkdownHeading } from "astro";

type Props = {
    headings: MarkdownHeading[];
    title: string;
};

const { headings, title } = Astro.props;
---

<toc-floating
    class="fixed z-50 flex flex-col items-end right-4 top-1/2 -translate-y-1/2
           xl:left-1/2 xl:ml-[30rem] xl:right-auto"
>
    <div class="relative group">
        <span
            class="absolute right-full mr-3 top-1/2 -translate-y-1/2 px-2 py-1 bg-zinc-900 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap"
        >
            Sommaire
        </span>

        <button
            id="toc-toggle"
            class="relative bg-white dark:bg-zinc-800 text-black dark:text-white p-0 rounded-full shadow-xl hover:shadow-2xl transition-all duration-300 z-50 flex items-center justify-center w-12 h-12 border-2 border-transparent overflow-hidden"
            aria-label="Table des matières"
        >
            <svg
                class="absolute inset-0 w-full h-full -rotate-90"
                viewBox="0 0 100 100"
            >
                <circle
                    cx="50"
                    cy="50"
                    r="45"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="4"
                    class="text-zinc-100 dark:text-zinc-700"></circle>
                <circle
                    id="toc-progress"
                    cx="50"
                    cy="50"
                    r="45"
                    fill="none"
                    stroke="#facd06"
                    stroke-width="6"
                    stroke-dasharray="283"
                    stroke-dashoffset="283"
                    stroke-linecap="round"
                    class="transition-all duration-150"></circle>
            </svg>
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="z-10"
            >
                <line x1="8" y1="6" x2="21" y2="6"></line>
                <line x1="8" y1="12" x2="21" y2="12"></line>
                <line x1="8" y1="18" x2="21" y2="18"></line>
                <line x1="3" y1="6" x2="3.01" y2="6"></line>
                <line x1="3" y1="12" x2="3.01" y2="12"></line>
                <line x1="3" y1="18" x2="3.01" y2="18"></line>
            </svg>
        </button>
    </div>

    <nav
        id="toc-content"
        class="absolute right-0 top-14 bg-white/95 dark:bg-zinc-900/95 backdrop-blur-md p-5 rounded-2xl shadow-2xl w-72 transform scale-0 origin-top-right transition-all duration-300 opacity-0 invisible border border-zinc-200 dark:border-zinc-800"
    >
        <div
            class="flex items-center justify-between mb-4 border-b border-zinc-100 dark:border-zinc-800 pb-2"
        >
            <a
                href="#"
                class="block text-base font-black mb-4 text-black dark:text-white hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors leading-tight no-underline"
                id="toc-title"
            >
                {title}
            </a>
            <button
                id="toc-close"
                class="text-zinc-400 hover:text-black dark:hover:text-white transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="18" y1="6" x2="6" y2="18"></line><line
                        x1="6"
                        y1="6"
                        x2="18"
                        y2="18"></line></svg
                >
            </button>
        </div>

        <ul
            class="space-y-1 max-h-[50vh] overflow-y-auto overflow-x-hidden list-none px-2 m-0
                   [&::-webkit-scrollbar]:w-[4px] [&::-webkit-scrollbar-track]:bg-transparent
                   [&::-webkit-scrollbar-thumb]:bg-zinc-500/20 [&::-webkit-scrollbar-thumb]:rounded-full"
        >
            {
                headings.map((heading) => (
                    <li class="text-sm font-medium">
                        <a
                            href={`#${heading.slug}`}
                            data-slug={heading.slug}
                            class="toc-link block py-1.5 px-2 rounded-lg text-zinc-600 dark:text-zinc-400 hover:text-black dark:hover:text-white hover:bg-yellow-50 dark:hover:bg-yellow-400/10 transition-all no-underline break-words"
                        >
                            {heading.text}
                        </a>
                    </li>
                ))
            }
        </ul>
    </nav>
</toc-floating>

<script>
    class TOCFloating extends HTMLElement {
        constructor() {
            super();
            const toggleBtn = this.querySelector("#toc-toggle");
            const closeBtn = this.querySelector("#toc-close");
            const content = this.querySelector("#toc-content");
            const titleLink = this.querySelector("#toc-title");
            const progressCircle = this.querySelector(
                "#toc-progress",
            ) as SVGCircleElement;
            const container = this;

            if (toggleBtn && content) {
                const toggle = () => {
                    const isExpanded = content.classList.contains("scale-100");
                    if (isExpanded) {
                        this.closeTOC();
                    } else {
                        this.openTOC();
                    }
                };

                toggleBtn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    toggle();
                });

                if (closeBtn)
                    closeBtn.addEventListener("click", () => this.closeTOC());

                document.addEventListener("click", (e) => {
                    if (
                        !this.contains(e.target as Node) &&
                        content.classList.contains("scale-100")
                    ) {
                        this.closeTOC();
                    }
                });

                if (titleLink) {
                    titleLink.addEventListener("click", (e) => {
                        e.preventDefault();
                        window.scrollTo({ top: 0, behavior: "smooth" });
                        this.closeTOC();
                    });
                }

                const tocLinks = content.querySelectorAll(".toc-link");
                tocLinks.forEach((link) => {
                    link.addEventListener("click", () => {
                        setTimeout(() => this.closeTOC(), 100);
                    });
                });

                const updateProgress = () => {
                    const winScroll =
                        document.body.scrollTop ||
                        document.documentElement.scrollTop;
                    const height =
                        document.documentElement.scrollHeight -
                        document.documentElement.clientHeight;
                    const scrolled = (winScroll / height) * 100;

                    if (progressCircle) {
                        const radius = progressCircle.r.baseVal.value;
                        const circumference = 2 * Math.PI * radius;
                        const offset =
                            circumference - (scrolled / 100) * circumference;
                        progressCircle.style.strokeDashoffset =
                            offset.toString();
                    }
                };

                const headingElements = Array.from(tocLinks)
                    .map((link) =>
                        document.getElementById(
                            link.getAttribute("data-slug") || "",
                        ),
                    )
                    .filter((h): h is HTMLElement => h !== null);

                const activeClasses = [
                    "bg-yellow-400",
                    "text-black",
                    "font-bold",
                    "shadow-sm",
                    "translate-x-1",
                ];

                const updateActiveHighlight = () => {
                    const scrollPos = window.scrollY + 150;

                    let currentId: string | null = null;
                    for (const heading of headingElements) {
                        if (heading.offsetTop <= scrollPos) {
                            currentId = heading.id;
                        } else {
                            break;
                        }
                    }

                    tocLinks.forEach((link) => {
                        if (link.getAttribute("data-slug") === currentId) {
                            link.classList.add(...activeClasses);
                        } else {
                            link.classList.remove(...activeClasses);
                        }
                    });
                };

                const anchor = document.getElementById("toc-anchor");
                const handleScroll = () => {
                    updateProgress();
                    updateActiveHighlight();
                    if (!anchor) return;
                    const anchorRect = anchor.getBoundingClientRect();
                    const viewportCenter = window.innerHeight / 2;

                    if (anchorRect.top > viewportCenter) {
                        container.style.position = "fixed";
                        container.style.top = `${anchorRect.top}px`;
                        container.style.transform = "none";
                    } else {
                        container.style.position = "fixed";
                        container.style.top = "50%";
                        container.style.transform = "translateY(-50%)";
                    }
                };

                window.addEventListener("scroll", handleScroll);
                window.addEventListener("resize", handleScroll);
                handleScroll();
            }
        }

        openTOC() {
            const content = this.querySelector("#toc-content");
            if (!content) return;
            content.classList.remove("scale-0", "opacity-0", "invisible");
            content.classList.add("scale-100", "opacity-100", "visible");
        }

        closeTOC() {
            const content = this.querySelector("#toc-content");
            if (!content) return;
            content.classList.remove("scale-100", "opacity-100", "visible");
            content.classList.add("scale-0", "opacity-0", "invisible");
        }
    }

    customElements.define("toc-floating", TOCFloating);
</script>
