---
import { getSeriesPosts } from "src/utils/blogUtils";
import { getUrl } from "src/utils/blogUtils";

type Props = {
    seriesName: string;
    currentPart: number;
};

const { seriesName, currentPart } = Astro.props;
const seriesPosts = await getSeriesPosts(seriesName);
---

{
    seriesPosts.length > 1 && (
        <nav
            class="my-6 rounded-xl border border-neutral-200 dark:border-zinc-700 bg-neutral-50 dark:bg-zinc-900 overflow-hidden"
            aria-label={`Série : ${seriesName}`}
            data-pagefind-ignore
        >
            <div class="flex items-center gap-2 px-4 py-3 bg-gradient-to-r from-neutral-800 to-neutral-600 dark:from-zinc-800 dark:to-zinc-700">
                <img
                    src={import.meta.env.BASE_URL + "/images/logo.png"}
                    alt=""
                    aria-hidden="true"
                    class="h-7 w-7 rounded-full object-cover"
                />
                <span class="text-white text-sm font-semibold tracking-wide">
                    Série : <span class="text-yellow-400">{seriesName}</span>
                </span>
            </div>

            <ol class="list-none m-0 p-0 divide-y divide-neutral-200 dark:divide-zinc-700">
                {seriesPosts.map((post) => {
                    const isCurrent = post.data.series?.part === currentPart;
                    return (
                        <li
                            class={`flex items-baseline gap-3 px-4 py-3 transition-colors ${isCurrent ? "bg-yellow-50 dark:bg-zinc-800" : "hover:bg-neutral-100 dark:hover:bg-zinc-800"}`}
                        >
                            <span
                                class={`shrink-0 text-xs font-bold uppercase tracking-widest w-16 ${isCurrent ? "text-yellow-600 dark:text-yellow-400" : "text-neutral-400 dark:text-zinc-500"}`}
                            >
                                Partie {post.data.series?.part}
                            </span>
                            {isCurrent ? (
                                <span
                                    class="text-base font-bold text-neutral-900 dark:text-white"
                                    aria-current="page"
                                >
                                    {post.data.title}
                                </span>
                            ) : (
                                <a
                                    href={getUrl(post)}
                                    class="text-base no-underline text-neutral-700 dark:text-zinc-300 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors"
                                >
                                    {post.data.title}
                                </a>
                            )}
                        </li>
                    );
                })}
            </ol>
        </nav>
    )
}
