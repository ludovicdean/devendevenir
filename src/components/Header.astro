---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import SocialLinks from "./SocialLinks.astro";
import SearchTrigger from "./SearchTrigger.astro";
import MobileMenuToggle from "./MobileMenuToggle.astro";
---

<header
  class="relative pt-2 bg-gradient-to-br from-neutral-800 to-neutral-400 dark:from-neutral-400 dark:to-neutral-800"
>
  <div id="desktopMenu" class="mx-auto w-[900px] max-w-[calc(100%-2rem)] px-4">
    <div class="flex items-center justify-between">
      <a href={import.meta.env.BASE_URL} class="flex items-center" id="logo">
        <img
          src={import.meta.env.BASE_URL + "/images/logo.png"}
          alt="Logo"
          class="h-16 w-auto"
        />
      </a>

      <div class="flex items-center space-x-4">
        <a href={import.meta.env.BASE_URL} class="hidden md:block" id="accueil">
          <span
            class="self-center whitespace-nowrap text-2xl font-semibold text-white"
          >
            Dev<span
              class="inline-block animate-bounce text-yellow-400 ease-in-out"
              >En</span
            >Devenir
          </span>
        </a>
        <MobileMenuToggle />
      </div>
    </div>

    <div class="hidden items-center justify-between md:flex">
      <ul
        class="m-0 flex list-none items-center space-x-8 p-0 font-medium rtl:space-x-reverse"
      >
        <li>
          <HeaderLink href="/about" data-testid="a-propos-desktop"
            >À propos</HeaderLink
          >
        </li>
        <li>
          <HeaderLink
            href="/talks-podcasts"
            data-testid="talks-podcasts-desktop"
          >
            Talks/Podcasts
          </HeaderLink>
        </li>
      </ul>

      <div class="flex items-center space-x-4">
        <SocialLinks iconSize="size-6" />
        <span class="h-6 w-px bg-white/30 text-white/30"></span>
        <div class="flex items-center space-x-3">
          <ThemeToggle />
          <SearchTrigger />
        </div>
      </div>
    </div>
  </div>

  <div
    id="overlay"
    class="pointer-events-none fixed inset-0 z-30 bg-slate-900/50 opacity-0 transition-opacity duration-300 md:hidden"
    hidden
  >
  </div>

  <div
    id="mobileMenu"
    class="pointer-events-none fixed left-0 right-0 top-[80px] z-40 justify-center px-4 opacity-0 -translate-y-5 transition-all duration-300 ease-out md:hidden"
    hidden
  >
    <div class="mt-4 w-full max-w-md rounded-lg bg-black p-6 shadow-lg">
      <nav aria-label="Navigation mobile">
        <ul
          class="m-0 flex list-none flex-col items-center space-y-4 p-0 font-medium"
        >
          <li>
            <HeaderLink href="/about" data-testid="a-propos-mobile"
              >À propos</HeaderLink
            >
          </li>
          <li>
            <HeaderLink
              href="/talks-podcasts"
              data-testid="talks-podcasts-mobile"
            >
              Talks/Podcasts
            </HeaderLink>
          </li>
          <li class="flex space-x-6 text-white">
            <SocialLinks iconSize="size-6" />
          </li>
          <li class="flex space-x-6 text-white">
            <ThemeToggle iconSize="size-6" />
            <SearchTrigger iconSize="size-6" />
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <script>
    const menuToggle = document.getElementById("menuToggle");
    const mobileMenu = document.getElementById("mobileMenu");
    const overlay = document.getElementById("overlay");
    const menuIcon = document.getElementById("menuIcon");
    const closeIcon = document.getElementById("closeIcon");

    if (menuToggle && mobileMenu && overlay && menuIcon && closeIcon) {
      let isOpen = false;

      const openMenu = () => {
        isOpen = true;

        mobileMenu.hidden = false;
        overlay.hidden = false;

        requestAnimationFrame(() => {
          mobileMenu.classList.add("flex", "active");
          mobileMenu.classList.remove(
            "pointer-events-none",
            "opacity-0",
            "-translate-y-5",
          );
          mobileMenu.classList.add(
            "pointer-events-auto",
            "opacity-100",
            "translate-y-0",
          );

          overlay.classList.remove("pointer-events-none", "opacity-0");
          overlay.classList.add("pointer-events-auto", "opacity-100");
        });

        menuIcon.classList.add("hidden");
        closeIcon.classList.remove("hidden");
        menuToggle.setAttribute("aria-expanded", "true");
        menuToggle.setAttribute("aria-label", "Fermer le menu");
        document.body.classList.add("overflow-hidden");
      };

      const closeMenu = () => {
        isOpen = false;

        mobileMenu.classList.remove(
          "pointer-events-auto",
          "opacity-100",
          "translate-y-0",
          "flex",
        );
        mobileMenu.classList.add(
          "pointer-events-none",
          "opacity-0",
          "-translate-y-5",
        );

        overlay.classList.remove("pointer-events-auto", "opacity-100");
        overlay.classList.add("pointer-events-none", "opacity-0");

        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        menuToggle.setAttribute("aria-expanded", "false");
        menuToggle.setAttribute("aria-label", "Ouvrir le menu");
        document.body.classList.remove("overflow-hidden");

        window.setTimeout(() => {
          if (!isOpen) {
            mobileMenu.hidden = true;
            overlay.hidden = true;
          }
        }, 300);
      };

      const toggleMenu = () => {
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      };

      menuToggle.addEventListener("click", toggleMenu);
      overlay.addEventListener("click", closeMenu);

      document.querySelectorAll("#mobileMenu a").forEach((link) => {
        link.addEventListener("click", closeMenu);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && isOpen) {
          closeMenu();
        }
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 768 && isOpen) {
          closeMenu();
        }
      });
    }
  </script>
</header>
